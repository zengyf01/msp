# 密算平台前端 Dockerfile
FROM node:18-alpine AS builder

WORKDIR /app

COPY msp-frontend/package.json .
RUN npm install

COPY msp-frontend/ .

RUN npm run build

FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]